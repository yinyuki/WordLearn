/* pages/profile/profile.wxss */
.user-card { text-align: center; padding: 40rpx; }
.user-info { margin-bottom: 30rpx; }
.avatar-wrapper { position: relative; display: inline-block; margin-bottom: 20rpx; }
.avatar { border: 6rpx solid #fff; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1); }
.camera-icon {
  position: absolute; bottom: 0; right: 0;
  width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5);
  border-radius: 50%; font-size: 24rpx; color: #fff;
  display: flex; align-items: center; justify-content: center;
}
.username { font-size: 36rpx; font-weight: bold; color: #303133; display: block; }
.logout-btn { width: 100%; }

.function-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx;
  margin: 20rpx 0; padding: 20rpx;
  background: #fff; border-radius: 16rpx;
}
.function-item {
  width: calc(20% - 13rpx);
  display: flex; flex-direction: column; align-items: center; padding: 16rpx 0;
}
.function-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.function-text { font-size: 22rpx; color: #606266; }

.setting-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; }
.limit-control { display: flex; align-items: center; background: #f5f7fa; border-radius: 8rpx; }
.control-btn { width: 60rpx; height: 60rpx; line-height: 60rpx; text-align: center; font-size: 32rpx; }
.limit-num { width: 80rpx; text-align: center; font-weight: bold; }

.form-section { padding: 10rpx 0; }
.section-label { font-size: 28rpx; color: #409eff; font-weight: 500; margin-bottom: 20rpx; display: block; }
.mt-20 { margin-top: 20rpx; }
