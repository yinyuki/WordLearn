<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info">
      <view class="avatar-wrapper" bindtap="changeAvatar">
        <image class="avatar avatar-large" src="{{userInfo.avatar || defaultAvatar}}"></image>
        <view class="camera-icon">📷</view>
      </view>
      <text class="username">{{userInfo.username || 'User'}}</text>
    </view>
    <button class="logout-btn btn-danger" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 功能入口 -->
  <view class="function-grid">
    <view class="function-item" bindtap="goLearn">
      <text class="function-icon">📖</text>
      <text class="function-text">学习</text>
    </view>
    <view class="function-item" bindtap="goStats">
      <text class="function-icon">📊</text>
      <text class="function-text">统计</text>
    </view>
    <view class="function-item" bindtap="goMistakes">
      <text class="function-icon">📝</text>
      <text class="function-text">错题</text>
    </view>
    <view class="function-item" bindtap="goRank">
      <text class="function-icon">🏆</text>
      <text class="function-text">榜单</text>
    </view>
    <view class="function-item" bindtap="goExtension">
      <text class="function-icon">📚</text>
      <text class="function-text">拓展</text>
    </view>
  </view>

  <!-- 设置区域 -->
  <view class="card">
    <view class="card-header">
      <view class="card-title">📅 学习计划</view>
    </view>
    <view class="setting-item">
      <text>每日新词上限</text>
      <view class="limit-control">
        <text class="control-btn" bindtap="decreaseLimit">-</text>
        <text class="limit-num">{{dailyLimit}}</text>
        <text class="control-btn" bindtap="increaseLimit">+</text>
      </view>
    </view>
  </view>

  <!-- 账号安全 -->
  <view class="card">
    <view class="card-header">
      <view class="card-title">🔒 账号安全</view>
    </view>
    <view class="form-section">
      <text class="section-label">修改用户名</text>
      <input class="input" placeholder="新用户名" value="{{usernameForm.newUsername}}" bindinput="onNewUsernameInput" />
      <input class="input mt-20" placeholder="当前密码" password value="{{usernameForm.password}}" bindinput="onUsernamePwdInput" />
      <button class="btn-primary mt-20" bindtap="updateUsername">保存</button>
    </view>
    <view class="divider"></view>
    <view class="form-section">
      <text class="section-label">修改密码</text>
      <input class="input" placeholder="原密码" password value="{{pwdForm.oldPassword}}" bindinput="onOldPwdInput" />
      <input class="input mt-20" placeholder="新密码" password value="{{pwdForm.newPassword}}" bindinput="onNewPwdInput" />
      <input class="input mt-20" placeholder="确认新密码" password value="{{pwdForm.confirmPassword}}" bindinput="onConfirmPwdInput" />
      <button class="btn-warning mt-20" bindtap="updatePassword">修改密码</button>
    </view>
  </view>
</view>
