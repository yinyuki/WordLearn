/* pages/stats/stats.wxss */
.header { text-align: center; margin-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #303133; display: block; }
.subtitle { font-size: 26rpx; color: #909399; margin-top: 10rpx; display: block; }

.stats-grid { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 30rpx; }
.stat-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.stat-value { font-size: 56rpx; font-weight: bold; display: block; }
.stat-label { font-size: 24rpx; color: #909399; margin-top: 10rpx; display: block; }

.week-chart { display: flex; justify-content: space-around; align-items: flex-end; height: 200rpx; padding-top: 20rpx; }
.day-bar { display: flex; flex-direction: column; align-items: center; }
.bar { width: 40rpx; border-radius: 8rpx 8rpx 0 0; min-height: 10rpx; }
.day-label { font-size: 22rpx; color: #909399; margin-top: 10rpx; }
