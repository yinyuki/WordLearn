/* pages/community/community.wxss */
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; color: #303133; }
.btn-small { padding: 12rpx 24rpx; font-size: 24rpx; }

.post-list { display: flex; flex-direction: column; gap: 20rpx; }
.post-card { background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.post-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.post-meta { margin-left: 16rpx; }
.author { font-size: 28rpx; font-weight: 500; color: #303133; display: block; }
.time { font-size: 22rpx; color: #909399; }
.post-content { font-size: 28rpx; color: #606266; line-height: 1.6; margin-bottom: 16rpx; }
.post-actions { display: flex; gap: 40rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.action-item { font-size: 26rpx; color: #909399; }
.action-item.liked { color: #f56c6c; }

.post-input { width: 100%; height: 200rpx; background: #f5f7fa; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; margin-bottom: 20rpx; }
