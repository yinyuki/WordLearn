<!--pages/learn/learn.wxml-->
<view class="container">
  <!-- 进度显示 -->
  <view class="progress-header" wx:if="{{words.length > 0}}">
    <text class="progress-text">{{currentIndex + 1}} / {{words.length}}</text>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(currentIndex / words.length) * 100}}%"></view>
    </view>
  </view>

  <!-- 单词卡片 -->
  <view class="word-card" wx:if="{{currentWord}}">
    <view class="word-main">
      <text class="word">{{currentWord.originalText}}</text>
    </view>
    
    <view class="word-meaning" wx:if="{{showMeaning}}">
      <text class="meaning">{{currentWord.translation}}</text>
      <text class="note" wx:if="{{currentWord.note}}">📝 {{currentWord.note}}</text>
    </view>
    
    <view class="show-btn" wx:if="{{!showMeaning}}" bindtap="toggleMeaning">
      <text>👀 点击显示释义</text>
    </view>
  </view>

  <!-- 学习完成状态 -->
  <view class="empty-state" wx:if="{{isFinished && !loading}}">
    <text class="empty-icon">🎉</text>
    <text class="empty-text">学习任务已完成！</text>
    <button class="btn-primary" bindtap="goBack">返回首页</button>
  </view>

  <!-- 没有任务状态 -->
  <view class="empty-state" wx:if="{{!currentWord && !isFinished && !loading && words.length === 0}}">
    <text class="empty-icon">📚</text>
    <text class="empty-text">暂无学习任务</text>
    <text class="empty-hint">请先在词书中添加单词</text>
    <button class="btn-primary" bindtap="goBack">返回首页</button>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons" wx:if="{{currentWord && showMeaning}}">
    <button class="action-btn btn-danger" bindtap="markWrong">❌ 不认识</button>
    <button class="action-btn btn-success" bindtap="markRight">✅ 认识</button>
  </view>
</view>
