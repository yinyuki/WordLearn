<!--pages/index/index.wxml-->
<view class="container">
  <!-- 欢迎头部 -->
  <view class="welcome-header">
    <view class="user-info">
      <image class="avatar avatar-large" src="{{userInfo.avatar || defaultAvatar}}"></image>
      <view class="welcome-text">
        <text class="greeting">👋 你好，{{userInfo.username || 'User'}}</text>
        <text class="date">{{today}}</text>
      </view>
    </view>
  </view>

  <!-- 学习任务卡片 -->
  <view class="card task-card">
    <view class="card-header">
      <view class="card-title">📚 学习任务</view>
    </view>
    
    <!-- 任务统计 -->
    <view class="task-stats">
      <view class="stat-item" bindtap="goLearn" data-type="reviews">
        <text class="stat-num num-warning">{{taskInfo.reviews.length || 0}}</text>
        <text class="stat-label">待复习</text>
      </view>
      <view class="stat-item" bindtap="goLearn" data-type="newWords">
        <text class="stat-num num-success">{{taskInfo.newWords.length || 0}}</text>
        <text class="stat-label">新单词</text>
      </view>
      <view class="stat-item" bindtap="goLearn" data-type="todayWords">
        <text class="stat-num num-primary">{{taskInfo.todayWords.length || 0}}</text>
        <text class="stat-label">今日已学</text>
      </view>
    </view>

    <!-- 开始学习按钮 -->
    <view class="btn-group">
      <button 
        class="btn-warning" 
        bindtap="goLearn" 
        data-type="reviews"
        disabled="{{!taskInfo.reviews.length}}"
      >开始复习</button>
      <button 
        class="btn-success" 
        bindtap="goLearn" 
        data-type="newWords"
        disabled="{{!taskInfo.newWords.length}}"
      >学习新词</button>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goStats">
      <text class="entry-icon">📈</text>
      <text class="entry-text">学习统计</text>
    </view>
    <view class="entry-item" bindtap="goMistakes">
      <text class="entry-icon">📝</text>
      <text class="entry-text">错题本</text>
    </view>
    <view class="entry-item" bindtap="goRank">
      <text class="entry-icon">🏆</text>
      <text class="entry-text">排行榜</text>
    </view>
    <view class="entry-item" bindtap="goExtension">
      <text class="entry-icon">📚</text>
      <text class="entry-text">拓展学习</text>
    </view>
  </view>
</view>
