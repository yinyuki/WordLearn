/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
}
.circle-1 { width: 400rpx; height: 400rpx; top: -100rpx; left: -100rpx; }
.circle-2 { width: 300rpx; height: 300rpx; bottom: 100rpx; right: -100rpx; }

.login-card {
  width: 85%;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

.card-header { text-align: center; margin-bottom: 50rpx; }
.title { font-size: 48rpx; font-weight: bold; color: #2c3e50; display: block; }
.subtitle { font-size: 26rpx; color: #7f8c8d; margin-top: 10rpx; display: block; }

.tabs {
  display: flex;
  margin-bottom: 40rpx;
  background: #f5f7fa;
  border-radius: 40rpx;
  padding: 6rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #909399;
  transition: all 0.3s;
}
.tab.active {
  background: #409EFF;
  color: #fff;
  font-weight: 500;
}

.form { padding: 20rpx 0; }
.input-group { margin-bottom: 30rpx; }
.input {
  height: 96rpx;
  background: #f5f7fa;
  border-radius: 48rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin-top: 30rpx;
  font-size: 32rpx;
}

.footer {
  position: absolute;
  bottom: 40rpx;
  color: rgba(0, 0, 0, 0.4);
  font-size: 24rpx;
}
