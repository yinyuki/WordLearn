<!--pages/rank/rank.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🏆 学习排行榜</text>
  </view>

  <!-- 前三名 -->
  <view class="top-three" wx:if="{{rankList.length >= 3}}">
    <view class="top-item second">
      <text class="medal">🥈</text>
      <image class="avatar avatar-medium" src="{{rankList[1].avatar || defaultAvatar}}"></image>
      <text class="name">{{rankList[1].username}}</text>
      <text class="score">{{rankList[1].totalWords}}词</text>
    </view>
    <view class="top-item first">
      <text class="medal">🥇</text>
      <image class="avatar avatar-large" src="{{rankList[0].avatar || defaultAvatar}}"></image>
      <text class="name">{{rankList[0].username}}</text>
      <text class="score">{{rankList[0].totalWords}}词</text>
    </view>
    <view class="top-item third">
      <text class="medal">🥉</text>
      <image class="avatar avatar-medium" src="{{rankList[2].avatar || defaultAvatar}}"></image>
      <text class="name">{{rankList[2].username}}</text>
      <text class="score">{{rankList[2].totalWords}}词</text>
    </view>
  </view>

  <!-- 排名列表 -->
  <view class="rank-list">
    <view class="rank-item" wx:for="{{rankList}}" wx:key="id" wx:if="{{index >= 3}}">
      <text class="rank-num">{{index + 1}}</text>
      <image class="avatar avatar-small" src="{{item.avatar || defaultAvatar}}"></image>
      <text class="rank-name">{{item.username}}</text>
      <text class="rank-score">{{item.totalWords}}词</text>
    </view>
  </view>

  <view class="empty" wx:if="{{rankList.length === 0 && !loading}}">
    <text class="empty-icon">🏆</text>
    <text class="empty-text">暂无排行数据</text>
  </view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>
