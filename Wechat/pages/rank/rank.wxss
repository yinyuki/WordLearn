/* pages/rank/rank.wxss */
.header { text-align: center; margin-bottom: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; }

.top-three { display: flex; justify-content: center; align-items: flex-end; gap: 20rpx; margin-bottom: 40rpx; padding: 40rpx 0; }
.top-item { display: flex; flex-direction: column; align-items: center; background: #fff; border-radius: 16rpx; padding: 24rpx; }
.top-item.first { transform: scale(1.1); box-shadow: 0 8rpx 24rpx rgba(255,215,0,0.3); }
.medal { font-size: 40rpx; margin-bottom: 10rpx; }
.name { font-size: 26rpx; color: #303133; margin-top: 10rpx; max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.score { font-size: 24rpx; color: #409eff; font-weight: bold; margin-top: 6rpx; }

.rank-list { background: #fff; border-radius: 16rpx; overflow: hidden; }
.rank-item { display: flex; align-items: center; padding: 24rpx 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 50rpx; font-size: 28rpx; font-weight: bold; color: #909399; }
.rank-name { flex: 1; margin-left: 20rpx; font-size: 28rpx; color: #303133; }
.rank-score { font-size: 28rpx; color: #409eff; font-weight: 500; }
